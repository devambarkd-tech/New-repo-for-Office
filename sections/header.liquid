{% assign mobile_menu = linklists[section.settings.mobile_menu].links %}
<div class="relative bg-white" x-data="{ mobileMenuOpen: false }">
  <div class="mx-auto px-4 sm:px-6">
    <div class="flex justify-between items-center py-6 md:justify-start md:space-x-10">
      <!-- STORE TITLE -->
      <div class="flex justify-start lg:flex-1 truncate ">
        <!-- Desktop Title -->
        <h1 class="hidden md:block text-xl font-bold truncate">
          {{ shop.name }}
        </h1>

        <!-- Mobile Title -->
        <h1 class="md:hidden text-xl font-bold truncate">
          {{ section.settings.mobile_h1 }}
        </h1>
      </div>

      <!-- MOBILE MENU BUTTON -->
      <div class="-mr-2 -my-2 ml-3 md:hidden">
        <button
          @click="mobileMenuOpen = true"
          type="button"
          class="bg-white p-2 inline-flex items-center justify-center focus:outline-none"
        >
          {% render 'icon-menu' %}
        </button>
      </div>

      <!-- DESKTOP MENU (ALWAYS MAIN MENU) -->
      <nav class="hidden md:flex space-x-10">
        {% for link in linklists['main-menu'].links %}
          {% if link.links != blank %}
            <div class="relative" x-data="{ open: false }" @click.away="open = false">
              <button
                @click="open = !open"
                type="button"
                class="inline-flex items-center text-base text-gray-500 hover:text-gray-900 focus:outline-none"
              >
                {{ link.title }}

                <span :class="{ 'rotate-180': open }" class="ml-2 transform transition-transform">
                  {% render 'icon-dropdown' %}
                </span>
              </button>

              <div
                x-show="open"
                x-transition:enter="transition ease-out duration-200"
                x-transition:enter-start="opacity-0 translate-y-1"
                x-transition:enter-end="opacity-100 translate-y-0"
                class="absolute z-10 -ml-5 mt-5 transform px-2 w-screen max-w-md sm:px-0 lg:left-1/2 lg:-translate-x-1/2"
                style="display:none;"
              >
                <div class="shadow-lg border ring-black ring-opacity-5 overflow-hidden rounded-lg">
                  <div class="relative grid gap-6 bg-white px-5 py-6 sm:gap-8 sm:p-8">
                    {% for childlink in link.links %}
                      <a href="{{ childlink.url }}" class="-m-3 p-3 flex items-start rounded-lg hover:bg-gray-100">
                        <div class="ml-4">
                          <p class="text-gray-900 text-base font-medium">
                            {{ childlink.title }}
                          </p>
                        </div>
                      </a>
                    {% endfor %}
                  </div>
                </div>
              </div>
            </div>

          {% else %}
            <a href="{{ link.url }}" class="text-base text-gray-500 hover:text-gray-900">
              {{ link.title }}
            </a>
          {% endif %}
        {% endfor %}
      </nav>

      <!-- RIGHT SIDE -->
      <div class="hidden md:flex items-center justify-end md:flex-1 space-x-5">
        <a href="{{ routes.cart_url }}" class="text-base text-gray-500 hover:text-gray-900">
          {% render 'icon-shopping-bag' %}
        </a>

        {% if shop.customer_accounts_enabled %}
          <a href="{{ routes.account_login_url }}" class="text-base text-gray-500 hover:text-gray-900"> Login </a>
          <a href="{{ routes.account_register_url }}" class="text-base text-gray-500 hover:text-gray-900"> Register </a>
        {% endif %}
      </div>
    </div>
  </div>

  <!-- MOBILE MENU -->

  <div
    x-show="mobileMenuOpen"
    class="absolute z-20 top-0 inset-x-0 p-2 transform origin-top-left md:hidden"
    @click.away="mobileMenuOpen = false"
    style="display:none;"
  >
    <div class="shadow-lg rounded-lg ring-1 ring-black ring-opacity-5 bg-white w-full">
      <div class="p-5 divide-y-2 divide-gray-50">
        <div class="flex items-center justify-end pb-3">
          <button
            @click="mobileMenuOpen = false"
            type="button"
            class="bg-white rounded-md p-2 text-gray-500"
          >
            {% render 'icon-close' %}
          </button>
        </div>

        <div class="pt-3">
          <nav class="grid gap-y-7">
            {% for link in mobile_menu %}
              {% if link.links != blank %}
                <div x-data="{ subMenuOpen: false }">
                  <button
                    @click="subMenuOpen = !subMenuOpen"
                    type="button"
                    class="text-base text-gray-500 hover:text-gray-900 flex items-center justify-between w-full"
                  >
                    <span>{{ link.title }}</span>

                    <span :class="{ 'rotate-180': subMenuOpen }" class="transform transition-transform">
                      {% render 'icon-dropdown' %}
                    </span>
                  </button>

                  <div x-show="subMenuOpen" class="pl-4">
                    {% for childlink in link.links %}
                      <a href="{{ childlink.url }}" class="block py-3 text-base text-gray-500 hover:text-gray-900">
                        {{ childlink.title }}
                      </a>
                    {% endfor %}
                  </div>
                </div>

              {% else %}
                <a href="{{ link.url }}" class="text-base text-gray-500 hover:text-gray-900">
                  {{ link.title }}
                </a>
              {% endif %}
            {% endfor %}
          </nav>
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "text",
      "id": "mobile_h1",
      "label": "Mobile Heading",
      "default": "Store"
    },
    {
      "type": "link_list",
      "id": "mobile_menu",
      "label": "Mobile Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
