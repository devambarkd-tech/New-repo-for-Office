<div class="max-w-7xl mx-auto px-4 py-10">
  <!-- Card Wrapper -->
  <div class="bg-white shadow-lg rounded-2xl overflow-hidden">
    <!-- Title Section -->
    <div class="border-b px-6 py-5 bg-gray-50">
      <h1 class="text-2xl md:text-3xl font-semibold text-gray-800 text-center">
        {{ page.title }}
      </h1>
    </div>

    <!-- Content Section -->
    <div class="px-6 py-6 prose max-w-none text-gray-700">
      {{ page.content }}
    </div>
  </div>
</div>
