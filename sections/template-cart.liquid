{% if cart.item_count > 0 %}
  <div class="p-4">
    <div class="flex flex-col max-w-6xl mx-auto my-10">
      <div class="flex items-end justify-between my-5">
        <h1 class="text-3xl my-4">Your cart</h1>
        <a
          href="{{ routes.all_products_collection_url }}"
          class="text-blue-600 hover:text-blue-800 font-medium underline"
          >Continue Shopping</a
        >
      </div>
    </div>

    <div class="flex max-w-6xl mx-auto my-10 flex-col">
      <form action="{{ routes.cart_url }}" method="POST" novalidate>
        <table class="min-w-full divide-y divide-gray-200 my-6 border rounded-lg overflow-hidden">
          <thead class="bg-gray-100">
            <tr>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Product</th>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Quantity</th>
              <th class="px-6 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                Total Price
              </th>
            </tr>
          </thead>

          <tbody class="bg-white divide-y divide-gray-100">
            {% for item in cart.items %}
              <tr class="hover:bg-gray-50 transition">
                <!-- Image -->
                <td class="py-4 px-4 flex flex-col justify-center">
                  <a href="{{ item.url }}">
                    {% if item.image %}
                      <img
                        src="{{ item.image | image_url: width: 200 }}"
                        alt="{{ item.title | escape }}"
                        class="w-24 h-24 object-cover rounded-md border"
                      >
                    {% else %}
                      {{ 'product-1' | placeholder_svg_tag: 'w-24 h-24 object-cover border rounded-md' }}
                    {% endif %}
                  </a>
                </td>

                <!-- Title + variant + remove -->
                <td class="py-4 px-2 flex flex-col justify-center">
                  <div class="flex flex-col justify-center">
                    <a href="{{ item.url }}" class="font-medium text-gray-800 hover:text-black mb-1">
                      {{ item.product.title | truncatewords: 5 }}
                    </a>
                    <span class="text-sm text-gray-500 mb-1">
                      {{ item.variant.title }}
                    </span>
                    <a
                      href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity=0"
                      class="text-sm font-medium text-red-500 hover:text-red-700"
                    >
                      Remove
                    </a>
                  </div>
                </td>

                <!-- Quantity -->
                <td class="py-4 px-2">
                  <input
                    type="number"
                    name="updates[]"
                    value="{{ item.quantity }}"
                    min="1"
                    max="5"
                    id="updates_{{ forloop.index }}"
                    class="w-20 border border-gray-300 rounded-md p-2 text-center focus:outline-none focus:ring-2 focus:ring-black"
                  >
                </td>

                <!-- Price -->
                <td class="py-4 px-2 font-medium text-gray-800">
                  {{ item.line_price | money }}
                </td>
              </tr>
            {% endfor %}
          </tbody>
        </table>

        <div class="flex flex-col md:flex-row items-center justify-center gap-8">
          <!-- Notes -->
          <div class="w-full my-4">
            <div class="flex flex-col items-center">
              <label for="cart_notes" class="my-2 text-sm font-medium text-gray-700"> Cart Notes </label>
              <textarea
                name="note"
                id="cart_notes"
                class="w-full border border-gray-300 rounded-md h-24 p-3 focus:outline-none focus:ring-2 focus:ring-black"
              ></textarea>
            </div>
          </div>

          <!-- Summary -->
          <div class="w-full my-4 md:w-80">
            {% for block in section.blocks %}
              {% case block.type %}
                {% when 'subtotal' %}
                  <h3 class="text-xl font-semibold text-gray-800 mb-4">Subtotal: {{ cart.total_price | money }}</h3>

                {% when 'update_button' %}
                  <!-- Update Button -->
                  <div class="my-2">
                    <button
                      type="submit"
                      name="update"
                      class="w-full bg-gray-200 text-gray-800 px-4 py-2 rounded-md text-sm font-medium hover:bg-gray-300 transition duration-200"
                    >
                      Update
                    </button>
                  </div>

                {% when 'checkout' %}
                  <!-- Checkout Button -->
                  <div class="my-2">
                    <button
                      type="submit"
                      name="checkout"
                      class="w-full bg-black text-white px-4 py-3 rounded-md text-sm font-semibold hover:bg-gray-800 transition duration-200"
                    >
                      Checkout
                    </button>
                  </div>
                {% else %}

              {% endcase %}
            {% endfor %}
          </div>
        </div>
      </form>
    </div>
  </div>
{% else %}
  <div class="flex items-center justify-center max-w-6xl h-60 my-4 mx-auto">
    <div class="text-center">
      <h1 class="text-3xl my-4">Your cart is empty</h1>
      <div class="my-4 py-4">
        <a
          href="{{ routes.all_products_collection_url }}"
          class="border border-gray-600 text-white bg-gray-600 px-8 py-3"
          >Continue Shopping</a
        >
      </div>
    </div>
  </div>
{% endif %}

{% schema %}
{
  "name": "Template Cart",
  "blocks": [
    {
      "type": "subtotal",
      "name": "Subtotal",
      "limit": 1
    },
    {
      "type": "update_button",
      "name": "Update Button",
      "limit": 1
    },
    {
      "type": "checkout_button",
      "name": "Checkout Button",
      "limit": 1
    }
  ],
  "settings": []
}
{% endschema %}
