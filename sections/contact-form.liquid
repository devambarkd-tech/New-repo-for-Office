<div class="flex items-center justify-center py-12 bg-gray-50 max-w-xl">
  {% form 'contact' %}
    <div class="w-full max-w-xl bg-white shadow-lg rounded-2xl p-8 space-y-6">
      <h2 class="text-2xl font-semibold text-center text-gray-800">Contact Us</h2>

      <!-- Name -->
      <div class="flex flex-col space-y-2">
        <label for="contact_form" class="text-sm font-medium text-gray-600"> Name </label>
        <input
          type="text"
          name="contact[name]"
          id="contact_form"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent transition"
          placeholder="Enter your name"
        >
      </div>

      <!-- Email -->
      <div class="flex flex-col space-y-2">
        <label for="contact_email" class="text-sm font-medium text-gray-600"> Email Address </label>
        <input
          type="email"
          name="contact[email]"
          id="contact_email"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent transition"
          placeholder="Enter your email"
        >
      </div>

      <!-- Message -->
      <div class="flex flex-col space-y-2">
        <label for="contact_message" class="text-sm font-medium text-gray-600"> Message </label>
        <textarea
          name="contact[body]"
          id="contact_message"
          rows="4"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-black focus:border-transparent transition resize-none"
          placeholder="Write your message..."
        ></textarea>
      </div>

      <!-- Button -->
      <button
        type="submit"
        class="w-full bg-black text-white py-3 rounded-lg font-medium hover:bg-gray-800 transition duration-300"
      >
        Submit Message
      </button>
    </div>
  {% endform %}
</div>

{% schema %}
{
  "name": "Contact Form",
  "presets": [
    {
      "name": "Contact Form"
    }
  ]
}
{% endschema %}
